# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forecast
TIMESCALE_URL=postgresql://postgres:postgres@localhost:5433/forecast_analytics

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Services (internal ports) ───────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PROJECT_SERVICE_PORT=3002
TIME_SERVICE_PORT=3003
USER_SERVICE_PORT=3004
REPORT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# ─── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
S3_BUCKET=forecast-dev-files

# ─── Email ──────────────────────────────────────────────────
SENDGRID_API_KEY=REPLACE_ME
EMAIL_FROM=noreply@forecast.app

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
