# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forecast
TIMESCALE_URL=postgresql://postgres:postgres@localhost:5433/forecast_analytics

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Services (internal ports) ───────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PROJECT_SERVICE_PORT=3002
TIME_SERVICE_PORT=3003
USER_SERVICE_PORT=3004
REPORT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# ─── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
S3_BUCKET=forecast-dev-files

# ─── Email ──────────────────────────────────────────────────
# Outbound mail goes through the dedicated Momentum mailbox
# (momentum@digitalnexa.com) using Gmail OAuth2. Reuses
# GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET below — the
# same OAuth client that powers "Sign in with Google".
#
# One-time setup:
#   1. GCP Console → APIs & Services → Library → enable Gmail API
#   2. APIs & Services → OAuth consent screen → add scope
#      https://www.googleapis.com/auth/gmail.send
#   3. APIs & Services → Credentials → your OAuth client →
#      add http://localhost:9999/oauth-callback to redirect URIs
#   4. Run: pnpm tsx scripts/get-gmail-refresh-token.ts
#   5. Sign in as momentum@digitalnexa.com when prompted
#   6. Paste the printed refresh token below
#   7. Remove the localhost redirect URI from step 3
GMAIL_USER=momentum@digitalnexa.com
GMAIL_OAUTH_REFRESH_TOKEN=REPLACE_ME
GMAIL_FROM_NAME=Momentum

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Public origin used in transactional emails (CTA links, brand assets).
# Must be a real public URL in production — Gmail can't fetch images
# from localhost, so any branding here that points at localhost will
# render as a broken icon for recipients.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Background worker (apps/jobs) ──────────────────────────
# The jobs process owns recurring schedules (BullMQ + Redis):
#   - budget-check       daily 09:00
#   - deadline-reminders daily 09:05
#   - timesheet-reminder Mon   09:00
#   - weekly-digest      Mon   09:05
#
# It must be deployed as its OWN long-running process (see Procfile
# entry `worker`). Without it, no scheduled email or Slack DM ever
# fires. The web tier alone is not enough.
#
# Required env:
#   REDIS_URL                  → schedule store + queue (above)
#   NOTIFICATION_SERVICE_URL   → where the worker POSTs jobs to. In
#                                production this is the private
#                                hostname of the notification process.
#                                Defaults to http://localhost:3006.
#   CRON_TZ                    → timezone for cron expressions. Pin
#                                this to keep DST from shifting the
#                                schedule by an hour twice a year.
#                                Defaults to Asia/Dubai.
NOTIFICATION_SERVICE_URL=http://localhost:3006
CRON_TZ=Asia/Dubai

# ─── Google Drive (per-user OAuth, used for "Export to Sheets") ─────
# Each user connects their own Drive in Settings -> Integrations. The
# refresh token Google issues is encrypted at rest with AES-256-GCM
# before going into the user_oauth_grants table.
#
# OAuth client: reuses the existing GOOGLE_OAUTH_CLIENT_ID/SECRET from
# the Sign-in with Google flow above (project nexttrack-493307). One
# Google OAuth client, three integrations:
#   - Sign in with Google (implicit flow)
#   - momentum@digitalnexa.com Gmail send (workspace mailbox)
#   - Per-user Drive/Sheets export (this section)
#
# Required GCP setup (one-time, per Google project):
#   1. https://console.cloud.google.com/apis/library/drive.googleapis.com?project=nexttrack-493307
#      -> Enable
#   2. https://console.cloud.google.com/apis/library/sheets.googleapis.com?project=nexttrack-493307
#      -> Enable
#   3. OAuth consent screen -> add scopes:
#        https://www.googleapis.com/auth/drive.file
#        https://www.googleapis.com/auth/spreadsheets
#      (userinfo.email is implicit; no need to add explicitly)
#   4. OAuth client credentials -> Authorized redirect URIs -> add:
#        http://localhost:3000/api/v1/integrations/google-drive/callback
#        https://momentum.digitalnexa.com/api/v1/integrations/google-drive/callback
#
# OAUTH_TOKEN_ENC_KEY encrypts user refresh tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64-char hex = 32 bytes = AES-256. Rotating it forces every user to
# reconnect Drive (their stored ciphertext can no longer be decrypted).
#
# OAUTH_STATE_SECRET signs the OAuth `state` parameter so the callback
# can identify which user is connecting. Defaults to JWT_PRIVATE_KEY
# if unset, which is fine for dev. Set it explicitly in prod.
OAUTH_TOKEN_ENC_KEY=REPLACE_ME_WITH_64_CHAR_HEX
OAUTH_STATE_SECRET=REPLACE_ME_OR_LEAVE_BLANK_TO_REUSE_JWT_KEY
